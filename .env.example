# Token addresses (Aptos)
AMI_TOKEN_ADDRESS=0xb36527754eb54d7ff55daf13bcb54b42b88ec484bd6f0e3b2e0d1db169de6451
USDT_TOKEN_ADDRESS=0x357b0b74bc833e95a115ad22604854d6b0fca151cecd94111770e5d6ffc9dc2b
APT_TOKEN_ADDRESS=0x1::aptos_coin::AptosCoin

# Trading symbol on CEX
CEX_SYMBOL=AMIUSDT

# Exchange fees (decimal, e.g. 0.001 = 0.1%)
BYBIT_FEE=0.001
MEXC_FEE=0.001

# Polling intervals (seconds)
MEXC_POLL_INTERVAL=0.4
ARB_CHECK_INTERVAL=0.1

# ------------------------------------------------------------------ #
#  TRADE EXECUTION
# ------------------------------------------------------------------ #
# Set to false to enable live trading. Default: true (paper mode only)
DRY_RUN=true

# Maximum USDT value per trade leg (safety cap)
TRADE_AMOUNT_USDT=10.0

# Bybit API credentials (required for live CEX-CEX / DEX-CEX arb)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Bybit MASTER key (required to create sub-accounts via create_accounts.py)
BYBIT_MASTER_KEY=
BYBIT_MASTER_SECRET=

# MEXC API credentials
MEXC_API_KEY=
MEXC_API_SECRET=

# MEXC MASTER key (required to create sub-accounts via create_accounts.py)
MEXC_MASTER_KEY=
MEXC_MASTER_SECRET=

# ------------------------------------------------------------------ #
#  Cellana swap event listener (Aptos fullnode gRPC)
# ------------------------------------------------------------------ #
CELLANA_SWAP_LISTENER_ENABLED=false
CELLANA_GRPC_ENDPOINT=127.0.0.1:50051
CELLANA_GRPC_USE_TLS=false
CELLANA_GRPC_API_KEY=
CELLANA_GRPC_API_KEY_HEADER=x-api-key
CELLANA_SWAP_EVENT_TYPE=0x4bf51972879e3b95c4781a5cdcb9e1ee24ef483e7d22f2d903626f126df62bd1::liquidity_pool::SwapEvent
CELLANA_SWAP_POOL_ADDRESS=
CELLANA_SWAP_STARTING_VERSION=0

                ami_start = bybit_ami_price_data.bid_qty
                trade_usdt = ami_start * ami_mid

            # Step 1: Sell AMI on Bybit
            usdt_out = ami_start * bybit_ami_price_data.effective_sell_price(ami_start) * (1.0 - bybit_fee_ami)

            # Step 2: Buy APT on MEXC
            apt_bought = usdt_out / (mexc_apt_price_data.effective_buy_price(usdt_out) * (1.0 + mexc_fee_apt))


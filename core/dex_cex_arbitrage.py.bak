                profit_usdt = profit_ami * ami_mid

                profit_pct = (profit_usdt / trade_usdt * 100) if trade_usdt > 0 else 0
                if profit_usdt > self.min_profit_ami_start or profit_pct > self.min_profit_pct_ami_start:

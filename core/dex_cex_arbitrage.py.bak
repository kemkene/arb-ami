        ):
            ami_mid = mexc_ami_price_data.mid if mexc_ami_price_data.mid > 0 else mexc_ami_price_data.bid
            trade_usdt = base_trade_usdt
            ami_start = trade_usdt / ami_mid

            # Cap by MEXC AMI sell liquidity
